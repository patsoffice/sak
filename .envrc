# Load the Nix flake dev shell for a reproducible Rust toolchain plus the
# shell-out CLIs (helm, kubectl, talosctl, gh). Guarded with `has nix` so
# direnv stays inert on machines without Nix — sak is a stock Cargo crate
# and builds fine with any system rustc + pkg-config + openssl.
if has nix; then
  use flake
else
  log_status "nix not found; skipping flake dev shell (use system rustc to build)"
fi
